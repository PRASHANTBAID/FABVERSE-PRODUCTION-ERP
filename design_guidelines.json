  "instructions_to_main_agent": [
    "Install 'lucide-react', 'recharts', 'date-fns', 'clsx', 'tailwind-merge' if not present.",
    "Ensure 'Barlow Condensed' font is loaded from Google Fonts for headings.",
    "Implement a ThemeProvider for Dark/Light mode toggle.",
    "Use 'sonner' for all toast notifications.",
    "Ensure all forms have validation (use react-hook-form + zod).",
    "Dashboard must show a pipeline view: Cutting -> Stitching -> Bartack -> Washing.",
    "Each lot card in the pipeline must show current status color-coded.",
    "Challan numbers must auto-increment (mock logic if backend not ready).",
    "Use the provided image URLs for section headers to give visual context.",
    "Login page should use the login_background image with a dark overlay."
  ],
  "universal_guidelines": [
    "Dark colors look good when used independently without gradients.",
    "Don't make generic centered layouts.",
    "Create depth through layered design elements with z-index hierarchy.",
    "Use glass-morphism effects with backdrop filters (12-24px blur) for sticky headers.",
    "Every interaction needs micro-animations - hover states, transitions.",
    "Use 2-3x more spacing than feels comfortable.",
    "Subtle grain textures, noise overlays, custom cursors, selection states.",
    "Component Reuse: Prioritize using pre-existing components from src/components/ui.",
    "Export Conventions: Components MUST use named exports.",
    "Toasts: Use 'sonner' for toasts.",
    "Use data-testid attributes for all interactive elements."
  ]
}